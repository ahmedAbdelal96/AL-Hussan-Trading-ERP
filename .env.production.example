# ==============================================================================
# ERP System — Production Environment Variables
# Copy this file to .env.production and fill in all values marked CHANGE_ME
# NEVER commit .env.production to version control
# ==============================================================================

# ==============================================================================
# DOCKER COMPOSE — used directly by docker-compose.yml for service configuration
# ==============================================================================
POSTGRES_DB=erp_db
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password_min32chars

REDIS_PASSWORD=CHANGE_ME_use_a_strong_redis_password

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=production
PORT=9000
API_PREFIX=api/v1
VITE_API_BASE_URL=/api/v1
HTTP_PORT=80
HTTPS_PORT=443
SYNC_PERMISSIONS_ON_BOOT=true

# Your public domain or VPS IP (used for file URL generation)
BASE_URL=https://yourdomain.com

# ==============================================================================
# DATABASE
# Automatically overridden in docker-compose.yml using the POSTGRES_* vars above.
# Keep this here as a fallback / for local debugging outside Docker.
# ==============================================================================
DATABASE_URL=postgresql://erp_user:CHANGE_ME_use_a_strong_password_min32chars@postgres:5432/erp_db?schema=public

DB_POOL_MIN=2
DB_POOL_MAX=10
DB_LOGGING=false
DB_SLOW_QUERY_THRESHOLD=500

# ==============================================================================
# INITIAL PRODUCTION ADMIN SEED
# Used by `npm run db:seed:production:superadmin`
# For the full foundation seed, also set the IT admin values below.
# ==============================================================================
PRODUCTION_SUPERADMIN_EMAIL=superadmin@yourdomain.com
PRODUCTION_SUPERADMIN_PASSWORD=CHANGE_ME_use_a_strong_password
PRODUCTION_SUPERADMIN_FIRST_NAME=Super
PRODUCTION_SUPERADMIN_LAST_NAME=Admin
PRODUCTION_SUPERADMIN_PHONE=+201234567890
PRODUCTION_SUPERADMIN_RESET_PASSWORD=false

PRODUCTION_IT_ADMIN_EMAIL=it-admin@yourdomain.com
PRODUCTION_IT_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password
PRODUCTION_IT_ADMIN_FIRST_NAME=IT
PRODUCTION_IT_ADMIN_LAST_NAME=Admin
PRODUCTION_IT_ADMIN_PHONE=+201111111111

# ==============================================================================
# REDIS
# Host/port are overridden in docker-compose.yml; password must match above.
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=erp:
REDIS_TTL_DEFAULT=300
REDIS_TTL_SHORT=60
REDIS_TTL_MEDIUM=600
REDIS_TTL_LONG=1800

# ==============================================================================
# JWT — Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==============================================================================
JWT_ACCESS_SECRET=CHANGE_ME_generate_64byte_hex_secret_1
JWT_REFRESH_SECRET=CHANGE_ME_generate_64byte_hex_secret_2
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

JWT_REFRESH_EXPIRES_IN_WITH_REMEMBER=7d
JWT_REFRESH_EXPIRES_IN_WITHOUT_REMEMBER=24h

# ==============================================================================
# CORS — Set to your frontend domain in production
# ==============================================================================
CORS_ENABLED=true
CORS_ORIGINS=https://yourdomain.com
CORS_CREDENTIALS=true

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=warn
LOGS_DIR=/app/logs
ENABLE_FILE_LOGGING=true

# ==============================================================================
# FILE UPLOAD
# ==============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_PATH=/app/uploads
STORAGE_ADAPTER=local
