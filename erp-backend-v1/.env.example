NODE_ENV=production
PORT=9000
API_PREFIX=api/v1

DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/erp_db?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=erp:
REDIS_TTL_DEFAULT=300
REDIS_TTL_SHORT=60
REDIS_TTL_MEDIUM=600
REDIS_TTL_LONG=1800

JWT_ACCESS_SECRET=YOUR_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_WITH_REMEMBER=7d
JWT_REFRESH_EXPIRES_IN_WITHOUT_REMEMBER=24h

CORS_ENABLED=true
CORS_ORIGINS=https://alhussan.tech,https://www.alhussan.tech
CORS_CREDENTIALS=true

RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

LOG_LEVEL=info
LOGS_DIR=./logs
ENABLE_FILE_LOGGING=true
PRETTY_CONSOLE_LOGS=false

MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_DIR=./uploads
UPLOAD_PATH=./uploads
BASE_URL=https://alhussan.tech
STORAGE_ADAPTER=local

PRODUCTION_SUPERADMIN_EMAIL=superadmin@alhussan.tech
PRODUCTION_SUPERADMIN_PASSWORD=YOUR_SUPERADMIN_PASSWORD
PRODUCTION_SUPERADMIN_FIRST_NAME=Ahmed
PRODUCTION_SUPERADMIN_LAST_NAME=Abdelal
PRODUCTION_SUPERADMIN_PHONE=+201234567890

PRODUCTION_IT_ADMIN_EMAIL=it-admin@alhussan.tech
PRODUCTION_IT_ADMIN_PASSWORD=YOUR_IT_ADMIN_PASSWORD
PRODUCTION_IT_ADMIN_FIRST_NAME=IT
PRODUCTION_IT_ADMIN_LAST_NAME=Admin
PRODUCTION_IT_ADMIN_PHONE=+201111111111
