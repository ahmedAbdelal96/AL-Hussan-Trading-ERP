// ============================================================================
// OPTIMIZED PRISMA SCHEMA FOR ERP SYSTEM
// Production-ready with performance optimizations
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS - Centralized type definitions
// ============================================================================

enum EmploymentType {
  PERMANENT // موظف دائم
  CONTRACT // عقد محدد المدة
  TEMPORARY // مؤقت
  PART_TIME // دوام جزئي
  FULL_TIME // دوام كامل
  FREELANCE // مستقل/حر
  CONSULTANT // استشاري
  INTERN // متدرب
  TRAINEE // متدرب تحت التجربة
  SEASONAL // موسمي
  ON_CALL // عند الطلب
  PROBATION // تحت الاختبار
  REMOTE // عن بُعد

  @@map("employment_type")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED

  @@map("employee_status")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum AssetType {
  VEHICLE
  EQUIPMENT
  MACHINERY
  TOOL
  COMPUTER
  FURNITURE
  OTHER

  @@map("asset_type")
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED

  @@map("asset_status")
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED

  @@map("maintenance_status")
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  SCHEDULED

  @@map("maintenance_type")
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("maintenance_priority")
}

enum SiteStatus {
  ACTIVE
  INACTIVE
  UNDER_PREPARATION
  CLOSED

  @@map("site_status")
}

enum ProjectStatus {
  DRAFT
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED

  @@map("project_status")
}

enum CostType {
  MAINTENANCE
  PURCHASE
  SALARY
  ALLOWANCE
  FUEL
  MATERIAL
  EQUIPMENT_RENTAL
  SUBCONTRACTOR
  UTILITY
  TRANSPORTATION
  INSURANCE
  TAX
  OTHER

  @@map("cost_type")
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  PARTIALLY_PAID
  OVERDUE

  @@map("payment_status")
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED // All installments paid

  @@map("loan_status")
}

enum AllowanceStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("allowance_status")
}

enum DeductionStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("deduction_status")
}

enum DeductionType {
  LOAN_REPAYMENT
  INSURANCE
  TAX
  PENALTY
  ADVANCE_DEDUCTION
  ABSENCE
  OTHER

  @@map("deduction_type")
}

enum LoanRepaymentSource {
  MANUAL
  PAYROLL_PROCESS

  @@map("loan_repayment_source")
}

enum AllowanceFrequency {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY

  @@map("allowance_frequency")
}

enum DocumentType {
  ID_CARD
  PASSPORT
  DRIVER_LICENSE
  CONTRACT
  CERTIFICATE
  INSURANCE
  REGISTRATION
  PERMIT
  INVOICE
  RECEIPT
  PHOTO
  WORK_ORDER
  REPORT
  WARRANTY
  BLUEPRINT
  INSPECTION
  OTHER

  @@map("document_type")
}

enum MediaCategory {
  PROGRESS_PHOTO
  PLAN
  REPORT
  INVOICE
  CONTRACT
  CERTIFICATE
  OTHER

  @@map("media_category")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  IMPORT
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  RESTORE
  ASSIGN_ROLE
  REVOKE_ROLE
  GRANT_CUSTOM_PERMISSION
  REVOKE_CUSTOM_PERMISSION

  @@map("audit_action")
}

enum AuditStatus {
  SUCCESS
  FAILED
  UNAUTHORIZED
  PARTIAL

  @@map("audit_status")
}

enum PermissionType {
  GRANT
  REVOKE

  @@map("permission_type")
}

enum AssignmentRole {
  MANAGER
  SUPERVISOR
  WORKER
  TECHNICIAN
  ENGINEER
  FOREMAN
  SAFETY_OFFICER
  QUALITY_CONTROL
  OTHER

  @@map("assignment_role")
}

enum OperatorRole {
  PRIMARY_DRIVER
  BACKUP_DRIVER
  OPERATOR
  TECHNICIAN
  ASSISTANT

  @@map("operator_role")
}

// ============================================================================
// AUTHENTICATION & USERS
// Optimized with proper data types and indexes
// ============================================================================

model User {
  id        String  @id @default(uuid()) @db.Uuid
  email     String  @unique @db.VarChar(255)
  password  String  @db.VarChar(255)
  firstName String  @map("first_name") @db.VarChar(100)
  lastName  String  @map("last_name") @db.VarChar(100)
  phone     String? @db.VarChar(20)
  isActive  Boolean @default(true) @map("is_active")

  // Profile Picture (simple string field)
  profilePicture String? @map("profile_picture") @db.VarChar(500) // File path

  // Performance: Cache last login for quick access
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp String?   @map("last_login_ip") @db.Inet

  // Login security and rate limiting
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lastFailedLoginAt   DateTime? @map("last_failed_login_at") @db.Timestamptz(3)
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(3)
  permanentlyLocked   Boolean   @default(false) @map("permanently_locked")
  permanentlyLockedAt DateTime? @map("permanently_locked_at") @db.Timestamptz(3)
  unlockAttemptCount  Int       @default(0) @map("unlock_attempt_count")

  // Token versioning for instant logout
  tokenVersion Int @default(1) @map("token_version")
  // Optimistic locking version for concurrent updates
  rowVersion Int @default(1) @map("row_version")

  // Soft delete
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by") @db.Uuid

  // Timestamps with timezone
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  userRoles             UserRole[]
  userCustomPermissions UserCustomPermission[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]

  // Created/Updated by relations
  rolesGranted          UserRole[]               @relation("GrantedBy")
  permissionsGranted    UserCustomPermission[]   @relation("PermissionGrantedBy")
  permissionHistory     PermissionGrantHistory[]
  sitesCreated          Site[]                   @relation("SiteCreatedBy")
  sitesUpdated          Site[]                   @relation("SiteUpdatedBy")
  employeesCreated      Employee[]               @relation("EmployeeCreatedBy")
  employeesUpdated      Employee[]               @relation("EmployeeUpdatedBy")
  employeeSalaryUpdates Employee[]               @relation("EmployeeSalaryUpdatedBy")
  salaryHistory         SalaryHistory[]          @relation("SalaryChangedBy")
  projectsCreated       Project[]                @relation("ProjectCreatedBy")
  projectsUpdated       Project[]                @relation("ProjectUpdatedBy")
  assetsCreated         Asset[]                  @relation("AssetCreatedBy")
  assetsUpdated         Asset[]                  @relation("AssetUpdatedBy")
  maintenanceCreated    MaintenanceRequest[]     @relation("MaintenanceCreatedBy")
  costsCreated          Cost[]                   @relation("CostCreatedBy")
  costsApproved         Cost[]                   @relation("CostApprovedBy")

  // Performance: Composite indexes for common queries
  @@index([email, isActive])
  @@index([lastLoginAt(sort: Desc)])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  isRevoked Boolean  @default(false) @map("is_revoked")

  // Security: Device fingerprinting
  userAgent String? @map("user_agent") @db.Text
  ipAddress String? @map("ip_address") @db.Inet

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Performance: Indexes for cleanup and validation
  @@index([userId, isRevoked])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// RBAC (Role-Based Access Control)
// Optimized for fast permission checking
// ============================================================================

model Role {
  id            String  @id @default(uuid()) @db.Uuid
  name          String  @unique @db.VarChar(100)
  nameAr        String? @map("name_ar") @db.VarChar(100) // Arabic name
  slug          String  @unique @db.VarChar(100) // For programmatic access
  description   String? @db.Text
  descriptionAr String? @map("description_ar") @db.Text // Arabic description
  isSystemRole  Boolean @default(false) @map("is_system_role")
  isActive      Boolean @default(true) @map("is_active")
  priority      Int     @default(0) // For role hierarchy

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([slug, isActive])
  @@index([priority])
  @@map("roles")
}

model Permission {
  id            String  @id @default(uuid()) @db.Uuid
  name          String  @unique @db.VarChar(100)
  nameAr        String? @map("name_ar") @db.VarChar(100) // Arabic name
  resource      String  @db.VarChar(50)
  action        String  @db.VarChar(50)
  description   String? @db.Text
  descriptionAr String? @map("description_ar") @db.Text // Arabic description

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  rolePermissions       RolePermission[]
  userCustomPermissions UserCustomPermission[]

  // Performance: Covering index for permission checks
  @@index([resource, action])
  @@index([name])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  // Temporary permission support
  isTemporary Boolean   @default(false) @map("is_temporary")
  grantedAt   DateTime  @default(now()) @map("granted_at") @db.Timestamptz(3)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)

  // Who granted it
  grantedBy String @map("granted_by") @db.Uuid

  // Status
  isActive     Boolean   @default(true) @map("is_active")
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  revokedBy    String?   @map("revoked_by") @db.Uuid
  revokeReason String?   @map("revoke_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantor User @relation("GrantedBy", fields: [grantedBy], references: [id])

  // Performance: Optimized for permission resolution
  @@unique([userId, roleId, isActive], name: "unique_active_user_role")
  @@index([userId, isActive])
  @@index([userId, isActive, expiresAt])
  @@index([expiresAt])
  @@map("user_roles")
}

model UserCustomPermission {
  id           String @id @default(uuid()) @db.Uuid
  userId       String @map("user_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  permissionType PermissionType @default(GRANT) @map("permission_type")

  // Temporary grant
  isTemporary Boolean   @default(false) @map("is_temporary")
  grantedAt   DateTime  @default(now()) @map("granted_at") @db.Timestamptz(3)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)

  grantedBy String @map("granted_by") @db.Uuid

  isActive  Boolean   @default(true) @map("is_active")
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  revokedBy String?   @map("revoked_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantor    User       @relation("PermissionGrantedBy", fields: [grantedBy], references: [id])

  @@unique([userId, permissionId, isActive], name: "unique_active_user_permission")
  @@index([userId, isActive])
  @@index([userId, isActive, expiresAt])
  @@index([expiresAt])
  @@map("user_custom_permissions")
}

model PermissionGrantHistory {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  action     String    @db.VarChar(50)
  targetType String    @map("target_type") @db.VarChar(50)
  targetId   String    @map("target_id") @db.Uuid
  grantedBy  String    @map("granted_by") @db.Uuid
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(3)
  reason     String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  grantor User @relation(fields: [grantedBy], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("permission_grant_history")
}

// ============================================================================
// DEPARTMENTS - الأقسام
// ============================================================================

model Department {
  id       String  @id @default(uuid()) @db.Uuid
  code     String  @unique @db.VarChar(50)   // e.g. "ENGINEERING"
  nameAr   String  @map("name_ar") @db.VarChar(100)
  nameEn   String  @map("name_en") @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")
  rowVersion Int   @default(1) @map("row_version")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  employees Employee[]
  positions Position[]
  contracts EmploymentContract[]

  @@index([isActive])
  @@map("departments")
}

// ============================================================================
// POSITIONS - الوظائف
// ============================================================================

model Position {
  id           String  @id @default(uuid()) @db.Uuid
  code         String  @unique @db.VarChar(50)  // e.g. "CIVIL_ENG"
  nameAr       String  @map("name_ar") @db.VarChar(100)
  nameEn       String  @map("name_en") @db.VarChar(100)
  level        String  @db.VarChar(20)           // executive | senior | mid | junior
  departmentId String? @map("department_id") @db.Uuid
  isActive     Boolean @default(true) @map("is_active")
  rowVersion   Int     @default(1) @map("row_version")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]
  contracts  EmploymentContract[]

  @@index([departmentId, isActive])
  @@map("positions")
}

// ============================================================================
// EMPLOYEES (HR MODULE)
// Optimized for frequent searches and filtering
// ============================================================================

model Employee {
  id String @id @default(uuid()) @db.Uuid

  // Basic Info - Optimized string lengths
  firstName  String  @map("first_name") @db.VarChar(100)
  lastName   String  @map("last_name") @db.VarChar(100)
  middleName String? @map("middle_name") @db.VarChar(100)

  // Unique identifiers - Critical indexes
  nationalId     String @unique @map("national_id") @db.VarChar(50)
  employeeNumber String @unique @map("employee_number") @db.VarChar(50)

  // Contact - Validated
  email          String? @unique @db.VarChar(255)
  phone          String? @db.VarChar(20)
  alternatePhone String? @map("alternate_phone") @db.VarChar(20)

  // Personal Info
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      Gender?
  nationality String?   @db.VarChar(100)

  // Address - Denormalized for performance
  address    String? @db.Text
  city       String? @db.VarChar(100)
  state      String? @db.VarChar(100)
  postalCode String? @map("postal_code") @db.VarChar(20)
  country    String? @db.VarChar(100)

  // Employment - Hot fields (frequently queried)
  employmentType    EmploymentType @map("employment_type")
  status            EmployeeStatus @default(ACTIVE)
  departmentId      String?        @map("department_id") @db.Uuid
  positionId        String?        @map("position_id") @db.Uuid
  hireDate          DateTime       @map("hire_date") @db.Date
  terminationDate   DateTime?      @map("termination_date") @db.Date
  terminationReason String?        @map("termination_reason") @db.Text
  rehireDate        DateTime?      @map("rehire_date") @db.Date
  rehireReason      String?        @map("rehire_reason") @db.Text

  // Emergency Contact
  emergencyContactName     String? @map("emergency_contact_name") @db.VarChar(200)
  emergencyContactPhone    String? @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactRelation String? @map("emergency_contact_relation") @db.VarChar(100)

  // Profile Picture
  profilePicture String? @map("profile_picture") @db.VarChar(500)

  notes String? @db.Text

  // ============================================================================
  // SALARY INFORMATION (Direct in Employee for Performance)
  // ============================================================================
  // The current active salary - denormalized for fast access
  // All changes are logged in SalaryHistory table
  // This eliminates need for JOIN on every query
  baseSalary         Decimal?  @default(0) @map("base_salary") @db.Decimal(12, 2)
  currency           String?   @default("SAR") @db.VarChar(3)
  lastSalaryUpdate   DateTime? @map("last_salary_update") @db.Timestamptz(3)
  lastSalaryUpdateBy String?   @map("last_salary_update_by") @db.Uuid

  // ============================================================================
  // ROW VERSIONING (Optimistic Locking for Concurrent Updates)
  // ============================================================================
  // Incremented on every update to prevent lost updates
  // Frontend must send current version when updating
  // If version mismatch = data changed by another user = reject update
  version Int @default(1)

  // Soft delete
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  creator       User  @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updater       User? @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])
  salaryUpdater User? @relation("EmployeeSalaryUpdatedBy", fields: [lastSalaryUpdateBy], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  position      Position?   @relation(fields: [positionId], references: [id])

  contracts          EmploymentContract[]
  documents          EmployeeDocument[]
  salaryHistory      SalaryHistory[] // Track all salary changes
  allowances         EmployeeAllowance[]
  loans              EmployeeLoan[]
  deductions         EmployeeDeduction[]
  payslips           Payslip[]
  projectAssignments ProjectEmployee[]
  assetAssignments   AssetEmployee[]
  assetOperations    AssetOperation[]

  // Performance: Covering indexes for common queries
  @@index([employeeNumber, status])
  @@index([nationalId, status])
  @@index([status, deletedAt])
  @@index([employmentType, status])
  @@index([departmentId, status])
  @@index([positionId])
  @@index([hireDate(sort: Desc)])
  @@index([email])
  @@map("employees")
}

model EmploymentContract {
  id String @id @default(uuid()) @db.Uuid

  employeeId String @map("employee_id") @db.Uuid

  contractType EmploymentType @map("contract_type")
  startDate    DateTime       @map("start_date") @db.Date
  endDate      DateTime?      @map("end_date") @db.Date
  isRenewable  Boolean        @default(false) @map("is_renewable")

  positionId   String? @map("position_id") @db.Uuid
  departmentId String? @map("department_id") @db.Uuid
  baseSalary   Decimal @map("base_salary") @db.Decimal(12, 2)

  contractTerms String? @map("contract_terms") @db.Text
  filePath      String? @map("file_path") @db.VarChar(500)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position   Position?   @relation(fields: [positionId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([employeeId, isActive])
  @@index([startDate, endDate])
  @@map("employment_contracts")
}

model EmployeeDocument {
  id String @id @default(uuid()) @db.Uuid

  employeeId String @map("employee_id") @db.Uuid

  documentType DocumentType @map("document_type")
  documentName String       @map("document_name") @db.VarChar(255)
  filePath     String       @map("file_path") @db.VarChar(500)
  fileSize     Int          @map("file_size")
  mimeType     String       @map("mime_type") @db.VarChar(100)

  issueDate  DateTime? @map("issue_date") @db.Date
  expiryDate DateTime? @map("expiry_date") @db.Date

  notes String? @db.Text

  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(3)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([expiryDate])
  @@map("employee_documents")
}

model ProjectDocument {
  id String @id @default(uuid()) @db.Uuid

  projectId String @map("project_id") @db.Uuid

  documentType DocumentType @map("document_type")
  documentName String       @map("document_name") @db.VarChar(255)
  filePath     String       @map("file_path") @db.VarChar(500)
  fileSize     Int          @map("file_size")
  mimeType     String       @map("mime_type") @db.VarChar(100)

  issueDate  DateTime? @map("issue_date") @db.Date
  expiryDate DateTime? @map("expiry_date") @db.Date

  notes String? @db.Text

  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiryDate])
  @@map("project_documents")
}

// ============================================================================
// PAYROLL
// ============================================================================

// ============================================================================
// SALARY HISTORY - Audit Trail for All Salary Changes
// ============================================================================
// Records every salary modification for compliance, auditing, and reporting
// Source tracks whether change was from dedicated salary update or employee edit
model SalaryHistory {
  id String @id @default(uuid()) @db.Uuid

  // Employee reference
  employeeId String @map("employee_id") @db.Uuid

  // Salary change details
  baseSalaryBefore Decimal @map("base_salary_before") @db.Decimal(12, 2)
  baseSalaryAfter  Decimal @map("base_salary_after") @db.Decimal(12, 2)

  // Change metadata
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(3)
  changedBy String   @map("changed_by") @db.Uuid

  // Why was the salary changed? (e.g., "Annual raise", "Promotion", "Adjustment")
  reason String? @db.VarChar(500)

  // Source of change for better traceability
  // MANUAL: Direct salary update via dedicated endpoint
  // EMPLOYEE_UPDATE: Changed during employee profile update
  // BULK_UPDATE: Part of bulk salary adjustment
  // MIGRATION: Initial data migration
  source String @default("MANUAL") @db.VarChar(50)

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changer  User     @relation("SalaryChangedBy", fields: [changedBy], references: [id])

  // Performance indexes for common queries
  @@index([employeeId, changedAt(sort: Desc)]) // Get employee history ordered by date
  @@index([changedAt(sort: Desc)]) // Recent changes across all employees
  @@index([changedBy]) // Changes by specific user
  @@map("salary_history")
}

model AllowanceType {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(100)
  description String? @db.Text
  defaultAmount Decimal? @map("default_amount") @db.Decimal(10, 2)
  isActive    Boolean @default(true) @map("is_active")
  rowVersion  Int     @default(1) @map("row_version")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy String   @map("created_by") @db.Uuid

  employeeAllowances EmployeeAllowance[]

  @@map("allowance_types")
}

model EmployeeAllowance {
  id String @id @default(uuid()) @db.Uuid

  employeeId      String @map("employee_id") @db.Uuid
  allowanceTypeId String @map("allowance_type_id") @db.Uuid

  amount    Decimal            @db.Decimal(10, 2)
  frequency AllowanceFrequency @default(MONTHLY)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  status AllowanceStatus @default(PENDING)

  approvedBy String?   @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at") @db.Timestamptz(3)

  rejectedBy     String?   @map("rejected_by") @db.Uuid
  rejectedAt     DateTime? @map("rejected_at") @db.Timestamptz(3)
  rejectedReason String?   @map("rejected_reason") @db.Text

  notes String? @db.Text

  // Soft Delete
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy String   @map("created_by") @db.Uuid
  rowVersion Int     @default(1) @map("row_version")

  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allowanceType AllowanceType @relation(fields: [allowanceTypeId], references: [id])

  @@unique([employeeId, allowanceTypeId, status], name: "unique_active_allowance")
  @@index([employeeId, status])
  @@index([employeeId, status, effectiveFrom, effectiveTo]) // Covering index for payroll active-allowance lookup
  @@index([employeeId, deletedAt])
  @@index([effectiveFrom, effectiveTo])
  @@index([status])
  @@map("employee_allowances")
}

model EmployeeLoan {
  id String @id @default(uuid()) @db.Uuid

  employeeId String @map("employee_id") @db.Uuid

  amount          Decimal @db.Decimal(12, 2)
  remainingAmount Decimal @map("remaining_amount") @db.Decimal(12, 2)

  installments      Int     @default(0)
  paidInstallments  Int     @default(0) @map("paid_installments")
  installmentAmount Decimal @map("installment_amount") @db.Decimal(10, 2)

  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date

  status LoanStatus @default(PENDING)

  purpose String? @db.Text
  notes   String? @db.Text

  approvedBy     String?   @map("approved_by") @db.Uuid
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz(3)
  rejectedReason String?   @map("rejected_reason") @db.Text

  // Soft Delete
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy String   @map("created_by") @db.Uuid
  rowVersion Int     @default(1) @map("row_version")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([employeeId, status, startDate, endDate]) // Covering index for payroll active-loan lookup
  @@index([status])
  @@index([endDate])
  @@map("employee_loans")
}

model EmployeeDeduction {
  id String @id @default(uuid()) @db.Uuid

  employeeId String @map("employee_id") @db.Uuid

  deductionType DeductionType @map("deduction_type")
  amount        Decimal       @db.Decimal(10, 2)

  deductionDate DateTime @map("deduction_date") @db.Date

  loanId String? @map("loan_id") @db.Uuid
  repaymentSource LoanRepaymentSource? @map("repayment_source")

  reason String? @db.Text
  notes  String? @db.Text

  status DeductionStatus @default(PENDING)

  approvedBy String?   @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at") @db.Timestamptz(3)

  rejectedBy     String?   @map("rejected_by") @db.Uuid
  rejectedAt     DateTime? @map("rejected_at") @db.Timestamptz(3)
  rejectedReason String?   @map("rejected_reason") @db.Text

  // Soft Delete
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy String?   @map("deleted_by") @db.Uuid
  rowVersion Int      @default(1) @map("row_version")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
